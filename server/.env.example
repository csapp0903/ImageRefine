# 阿里云 API 凭证（必填）
ALIBABA_ACCESS_KEY_ID=your-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-access-key-secret

# 阿里云区域（推荐 cn-shanghai，服务最全）
ALIBABA_REGION=cn-shanghai

# OSS 配置（必填，用于临时存储上传图片）
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# OSS 临时文件过期时间（秒），签名 URL 有效期
OSS_URL_EXPIRY=3600

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# API 限流（每分钟每 IP 最大请求数）
RATE_LIMIT_PER_MINUTE=30

# 可选：API Token 鉴权（留空则不校验）
API_TOKEN=
