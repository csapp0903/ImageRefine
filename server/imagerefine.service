[Unit]
Description=ImageRefine AI Proxy Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/imagerefine-server
ExecStart=/opt/imagerefine-server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
EnvironmentFile=/opt/imagerefine-server/.env

[Install]
WantedBy=multi-user.target
